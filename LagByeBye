local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("LagByeBye: PvP Optimizer", "Midnight")

-- Tabs
local Tab = Window:NewTab("Fruit & Gun VFX")
local Section = Tab:NewSection("Targeted Visual Removers")

-- Optimization Function
local function toggleVFX(nameKeywords, state)
    for _, v in pairs(game.Workspace:GetDescendants()) do
        -- Search for things named 'Dragon', 'Kitsune', etc.
        for _, keyword in pairs(nameKeywords) do
            if v.Name:find(keyword) or v.Parent.Name:find(keyword) then
                if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") then
                    v.Enabled = not state -- If 'state' is true, we DISABLE (enabled = false)
                end
            end
        end
    end
end

-- 1. Dragon Fruit Toggle
Section:NewToggle("Disable Dragon VFX", "Kills Dragon Breath and Transformations", function(state)
    _G.NoDragon = state
    toggleVFX({"Dragon", "FireBreath", "Transform"}, state)
end)

-- 2. Kitsune Fruit Toggle
Section:NewToggle("Disable Kitsune VFX", "Kills Fox Fire and Blue Tails", function(state)
    _G.NoKitsune = state
    toggleVFX({"Kitsune", "Fox", "BlueFire", "Tail"}, state)
end)

-- 3. Control Fruit Toggle
Section:NewToggle("Disable Control VFX", "Kills the 'Room' and Levitation effects", function(state)
    _G.NoControl = state
    toggleVFX({"Control", "Room", "Area", "Gamma"}, state)
end)

-- 4. Gun VFX Toggle
Section:NewToggle("Disable All Gun VFX", "Kills Soul Guitar, Kabucha, and Rifle shots", function(state)
    _G.NoGuns = state
    toggleVFX({"Bullet", "Shot", "Guitar", "Soul", "Beam", "Blast"}, state)
end)

-- AUTO-KILLER (Detects new moves while you play)
game.Workspace.DescendantAdded:Connect(function(obj)
    task.wait(0.1)
    if _G.NoDragon and (obj.Name:find("Dragon") or obj.Parent.Name:find("Dragon")) then
        if obj:IsA("ParticleEmitter") then obj.Enabled = false end
    end
    -- Repeat for others...
    if _G.NoKitsune and obj.Name:find("Kitsune") then
        if obj:IsA("ParticleEmitter") then obj.Enabled = false end
    end
end)

local Misc = Window:NewTab("Misc")
local MiscSection = Misc:NewSection("Global Boosts")

MiscSection:NewButton("Ultra Fast Mode (SmoothPlastic)", "Changes materials to be super fast", function()
    for _, v in pairs(game.Workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            v.Material = Enum.Material.SmoothPlastic
        end
    end
end)

print("LagByeBye Menu Loaded!")
