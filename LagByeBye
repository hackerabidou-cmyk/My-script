-- [[ LagByeBye: The Nuclear Performance Option ]] --
print("LagByeBye: Initiating 60 FPS Mode...")

local function optimize(obj)
    -- 1. Remove Heavy Particles (The 'Dragon/Control' lag)
    if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Smoke") then
        obj.Enabled = false
        
    -- 2. Delete Textures/Decals (Boosts GPU significantly)
    elseif obj:IsA("Decal") or obj:IsA("Texture") then
        obj:Destroy()
        
    -- 3. Target Mesh Detail (Dragon Scales, Control Domain Walls)
    elseif obj:IsA("MeshPart") or obj:IsA("SpecialMesh") then
        obj.RenderFidelity = Enum.RenderFidelity.Performance
        -- Option: obj.MeshId = "" -- Uncomment this if you want Dragon to be invisible cubes
        
    -- 4. Simplify Materials (Plastic is fastest to render)
    elseif obj:IsA("BasePart") then
        obj.Material = Enum.Material.Plastic
        obj.Reflectance = 0
        obj.CastShadow = false
    end
end

-- Wipe existing lag
for _, v in pairs(workspace:GetDescendants()) do
    optimize(v)
end

-- Wipe NEW lag as moves are used
workspace.DescendantAdded:Connect(function(newObj)
    task.wait() -- Small delay to ensure the object is fully in the game
    optimize(newObj)
end)

-- Global Lighting Fix
local lighting = game:GetService("Lighting")
lighting.GlobalShadows = false
lighting.FogEnd = 9e9
for _, effect in pairs(lighting:GetChildren()) do
    if effect:IsA("PostProcessEffect") then
        effect.Enabled = false
    end
end

print("60 FPS Optimization Active.")
