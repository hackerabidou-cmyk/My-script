-- [[ LagByeBye v3: Surgical VFX Menu ]] --
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("LagByeBye: PvP Optimizer", "Midnight")

-- Tabs
local Tab = Window:NewTab("Surgical VFX")
local Section = Tab:NewSection("Disable Specific Lag")

-- Settings table to keep track of toggles
_G.Settings = {
    NoDragon = false,
    NoKitsune = false,
    NoControl = false,
    NoGuns = false
}

-- The Surgical Function (Only kills what we ask for)
local function handleVFX(obj)
    local name = obj.Name:lower()
    local parentName = (obj.Parent and obj.Parent.Name:lower()) or ""

    -- 1. Dragon Logic
    if _G.Settings.NoDragon and (name:find("dragon") or parentName:find("dragon") or name:find("firebreath")) then
        if obj:IsA("ParticleEmitter") or obj:IsA("Trail") then obj.Enabled = false end
    end

    -- 2. Kitsune Logic
    if _G.Settings.NoKitsune and (name:find("kitsune") or name:find("fox") or name:find("bluefire") or name:find("tail")) then
        if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") then obj.Enabled = false end
    end

    -- 3. Control Logic
    if _G.Settings.NoControl and (name:find("control") or name:find("room") or name:find("gamma") or name:find("area")) then
        if obj:IsA("ParticleEmitter") or obj:IsA("MeshPart") then 
            -- We hide the 'Room' mesh specifically
            if name:find("room") or name:find("area") then obj.Transparency = 1 end
            if obj:IsA("ParticleEmitter") then obj.Enabled = false end
        end
    end

    -- 4. Gun Logic
    if _G.Settings.NoGuns and (name:find("bullet") or name:find("shot") or name:find("guitar") or name:find("soul")) then
        if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") then obj.Enabled = false end
    end
end

-- Toggles
Section:NewToggle("Disable Dragon VFX", "Stops Dragon Lag", function(state) _G.Settings.NoDragon = state end)
Section:NewToggle("Disable Kitsune VFX", "Stops Kitsune Lag", function(state) _G.Settings.NoKitsune = state end)
Section:NewToggle("Disable Control VFX", "Stops Control Lag", function(state) _G.Settings.NoControl = state end)
Section:NewToggle("Disable All Gun VFX", "Stops Soul Guitar/Gun Lag", function(state) _G.Settings.NoGuns = state end)

-- Listener: This is the 'Brain' that watches for new moves
game.Workspace.DescendantAdded:Connect(function(obj)
    task.wait(0.1) -- Wait for name to load
    handleVFX(obj)
end)

-- Global Performance (Lighting only, no texture deleting!)
local LightTab = Window:NewTab("Lighting")
local LightSec = LightTab:NewSection("Boost FPS (Keeps Visuals)")

LightSec:NewButton("Disable Shadows", "Removes shadows but keeps textures", function()
    game:GetService("Lighting").GlobalShadows = false
end)

LightSec:NewButton("Full Bright", "Makes everything clear", function()
    game:GetService("Lighting").Brightness = 2
    game:GetService("Lighting").ClockTime = 12
end)

print("LagByeBye v3 Loaded! No more ugly UI.")
