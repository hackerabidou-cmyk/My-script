-- [[ THE SURGICAL BRAIN ]] --
local function cleanVFX(obj)
    local name = obj.Name:lower()
    
    -- 1. DRAGON
    if _G.Settings.NoDragon and (name:find("dragon") or name:find("firebreath") or name:find("transform")) then
        if obj:IsA("ParticleEmitter") or obj:IsA("Trail") then obj.Enabled = false end
    end

    -- 2. KITSUNE
    if _G.Settings.NoKitsune and (name:find("kitsune") or name:find("fox") or name:find("tail") or name:find("bluefire")) then
        if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") then obj.Enabled = false end
    end

    -- 3. CONTROL
    if _G.Settings.NoControl and (name:find("control") or name:find("room") or name:find("area") or name:find("gamma")) then
        if obj:IsA("ParticleEmitter") then obj.Enabled = false end
        if name:find("room") or name:find("area") then obj.Transparency = 1 end
    end

    -- 4. ALL 14 GUNS (Total Wipeout)
    -- This targets common projectile names used by all Blox Fruit guns
    if _G.Settings.NoGuns then
        local gunKeywords = {"bullet", "shot", "muzzle", "flash", "flare", "smoke", "blast", "beam", "guitar", "soul", "acid", "serpent", "bizarre", "cannon", "musket", "rifle", "flintlock"}
        for _, word in pairs(gunKeywords) do
            if name:find(word) then
                if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") then
                    obj.Enabled = false
                end
            end
        end
    end
end

-- UI TABS
local Tab = Window:NewTab("VFX Removers")
local Section = Tab:NewSection("Targeted Fruits & Guns")

Section:NewToggle("Disable Dragon VFX", "No Dragon Lag", function(state) _G.Settings.NoDragon = state end)
Section:NewToggle("Disable Kitsune VFX", "No Kitsune Lag", function(state) _G.Settings.NoKitsune = state end)
Section:NewToggle("Disable Control VFX", "No Control Lag", function(state) _G.Settings.NoControl = state end)
Section:NewToggle("Disable ALL 14 Guns", "Soul Guitar, Acidum, etc.", function(state) _G.Settings.NoGuns = state end)

-- LISTENER
game.Workspace.DescendantAdded:Connect(function(obj)
    task.wait(0.1)
    cleanVFX(obj)
end)

